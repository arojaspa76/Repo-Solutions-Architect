# ─────────────────────────────────────────────────────────────────
# TechCorp LLM Infrastructure — Variables de Entorno
# Copiar este archivo a .env y completar los valores reales.
# NUNCA subir el .env al repositorio Git.
# ─────────────────────────────────────────────────────────────────

# Azure OpenAI Service
AZURE_OPENAI_ENDPOINT=https://oai-techcorp.openai.azure.com/
AZURE_OPENAI_KEY=your-openai-api-key-here
AZURE_OPENAI_CHAT_MODEL=gpt-4o
AZURE_OPENAI_EMBED_MODEL=text-embedding-3-small

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://srch-techcorp.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key-here
AZURE_SEARCH_INDEX=knowledge-base

# Azure Cosmos DB
COSMOS_ENDPOINT=https://cosmos-techcorp.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key-here
COSMOS_DATABASE=techcorp-chatbot
COSMOS_CONTAINER=conversations

# Azure Monitor (Application Insights)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=...

# Azure Cache for Redis (Capítulo 4 - Caché semántica)
REDIS_CONNECTION_STRING=redis-techcorp.redis.cache.windows.net:6380,password=your-password,ssl=True

# Configuración de la aplicación
PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development
