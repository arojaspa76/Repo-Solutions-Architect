# Project:     GenAIDemo
# Component:   Local development environment template
# Description: Copy to .env and fill in values — never commit real secrets here
# Owner:       Andrés Felipe Rojas Parra
# Created:     2026-07

ENVIRONMENT=dev
PROJECT_NAME=genaidemo

# Azure subscription / auth (DefaultAzureCredential picks these up if set)
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Resource names (outputs of ops/bicep/main.bicep for the dev environment)
RESOURCE_GROUP=genaidemo-rg-dev
KEY_VAULT_NAME=genaidemo-kv-dev
ACR_NAME=genaidemoacrdev

# Cosmos DB / Redis connection metadata (values fetched from Key Vault at runtime,
# these are only needed here for local integration test runs)
COSMOS_DB_ENDPOINT=
REDIS_HOST=
REDIS_SSL_PORT=6380

# Azure OpenAI (Azure AI Foundry)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=

# Entra ID app registration used for MSAL auth
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
