# ============================================================
# Variables de Entorno — Sesión 4
# Copiar a .env y completar con tus credenciales reales
# NUNCA commitear el archivo .env al repositorio
# ============================================================

# --- Configuración General ---
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=INFO
API_PORT=8000

# --- Ollama (LLM local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2:3b  # Recomendado para clase (2GB RAM)
OLLAMA_TIMEOUT=120                 # segundos

# --- Cache ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300              # 5 minutos
ENABLE_CACHE=true

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Azure Functions (para Capítulo 3) ---
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=rg-bsg-session4
AZURE_FUNCTION_APP_NAME=bsg-llm-function
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCP_REGION=us-central1
VERTEX_AI_MODEL=gemini-1.5-flash

# --- AWS ---
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_LAMBDA_FUNCTION_NAME=bsg-llm-function

# --- Monitoreo ---
PROMETHEUS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- Pruebas de Carga ---
LOAD_TEST_TARGET_URL=http://localhost:8000
LOAD_TEST_DURATION=300             # segundos
LOAD_TEST_USERS=50
