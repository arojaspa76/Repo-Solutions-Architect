# ============================================================
# .env.example — Copiar a .env y rellenar con tus valores
# IMPORTANTE: NUNCA subir el archivo .env a GitHub
# ============================================================

# --- Configuración General ---
APP_NAME="LLM Gateway API"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO
PORT=8000

# --- Ollama (LLM Local) ---
# Ollama corre por defecto en localhost:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=120

# --- Azure OpenAI ---
# Obtener en: portal.azure.com > Azure OpenAI > Keys and Endpoint
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Azure Container Registry (ACR) ---
ACR_NAME=youracrname
ACR_LOGIN_SERVER=youracrname.azurecr.io
AZURE_RESOURCE_GROUP=rg-llm-session3
AZURE_LOCATION=eastus

# --- Google Cloud (Vertex AI) ---
# Obtener service account en: console.cloud.google.com > IAM
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_CREDENTIALS_PATH=/path/to/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
VERTEX_AI_MODEL=gemini-1.5-pro

# --- Google Artifact Registry ---
GCP_ARTIFACT_REGISTRY=us-central1-docker.pkg.dev
GCP_ARTIFACT_REPO=llm-session3

# --- AWS (Amazon Bedrock) ---
# Configurar con: aws configure
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1
AWS_BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# --- AWS ECR ---
AWS_ACCOUNT_ID=123456789012
AWS_ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# --- Seguridad ---
API_KEY=your_internal_api_key_for_gateway
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
